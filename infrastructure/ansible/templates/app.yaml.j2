apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {{ item.name }}
  namespace: argocd
spec:
  project: default
  source:
    repoURL: https://github.com/Egorict/K8s.git
    targetRevision: HEAD
    path: {{ item.chart_path }}
  destination:
    server: https://kubernetes.default.svc
    namespace: default
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true